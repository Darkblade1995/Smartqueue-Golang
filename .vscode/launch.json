{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SmartQueue Debug",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/main.go",
      "dlvFlags": ["--check-go-version=false"],
      "env": {
        "REDIS_ADDR": "localhost:6379",
        "POSTGRES_URL": "postgres://postgres:postgres@localhost:5433/smartqueue?sslmode=disable",
        "HTTP_PORT": "8080"
      },
      "args": []
    },
    {
      "name": "SmartQueue Tests Debug",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/internal/retry",
      "dlvFlags": ["--check-go-version=false"],
      "args": ["-v"]
    }
  ]
}